TEXT 11896 -6240 Invisible 2 !.include ".\\proyecto_pcb_sensor_pt100.inc"\n.include ".\\INA826.lib"\n \n.step param TempNom list 0 20 50 100\n \n.param TEMP_MIN=0\n.param TEMP_MAX=100\n.param TEMP_ERR_C=5\n \n.param TempC={TempNom}\n \n.param TempLow={max(TEMP_MIN,TempNom-TEMP_ERR_C)}\n.param TempHigh={min(TEMP_MAX,TempNom+TEMP_ERR_C)}\n \n.param IRTD=0.5m\n.param VREF_VAL=1.25\n.param RSET_VAL={VREF_VAL/IRTD}\n \n.param RLEAD=1m\n \n.param RPT100_NOM={100*(1+3.9083e-3*TempNom-5.775e-7*TempNom*TempNom)}\n.param RPT100_LOW={100*(1+3.9083e-3*TempLow-5.775e-7*TempLow*TempLow)}\n.param RPT100_HIGH={100*(1+3.9083e-3*TempHigh-5.775e-7*TempHigh*TempHigh)}\n \n.param VPT100_NOM_mV={1000*IRTD*RPT100_NOM}\n.param VPT100_LOW_mV={1000*IRTD*RPT100_LOW}\n.param VPT100_HIGH_mV={1000*IRTD*RPT100_HIGH}\n \n.param T_ZERO=0\n.param RPT100_ZERO={100*(1+3.9083e-3*T_ZERO-5.775e-7*T_ZERO*T_ZERO)}\n.param V_OFFSET_PT100={IRTD*RPT100_ZERO}\n \n.param RG_INA=1k\n.param G_INA={1+49.4k/RG_INA}\n \n.tran 0 60m 0 10u startup uic\n \n.meas TRAN TEMPERATURA PARAM {TempNom}\n.meas TRAN TEMP_BAJA PARAM {TempLow}\n.meas TRAN TEMP_ALTA PARAM {TempHigh}\n \n.meas TRAN R_PT100_NOM PARAM {RPT100_NOM}\n.meas TRAN R_PT100_BAJA PARAM {RPT100_LOW}\n.meas TRAN R_PT100_ALTA PARAM {RPT100_HIGH}\n \n.meas TRAN V_PT100_NOM_mV PARAM {VPT100_NOM_mV}\n.meas TRAN V_PT100_BAJA_mV PARAM {VPT100_LOW_mV}\n.meas TRAN V_PT100_ALTA_mV PARAM {VPT100_HIGH_mV}\n \n.meas TRAN V_PT100_REAL_mV PARAM {1000*V(RTD_A,RTD_B)}\n.meas TRAN V_OUT_BBOX FIND V(OUT_PT100_BBOX) AT=50m\n \n.meas TRAN V_VOUT_FILT FIND V(VOUT_FILT) AT=50m\n.meas TRAN V_DROP_RBBOX FIND V(VOUT_FILT,OUT_PT100_BBOX) AT=50m\n \n.options reltol=1e-3\n.options abstol=1n\n.options vntol=1u\n.options gmin=1e-10\n.options gminsteps=0\n.options srcsteps=0\n \n.ic V(VREF_1V25)=1.25\n.ic V(NODO_SENSOR)=1.25\n.ic V(RTD_Iexc)=1.38\n.ic V(RTD_A)=1.38\n.ic V(RTD_B)=1.25\n.ic V(RTD_SENSOR)=1.25\n.ic V(VOUT_FILT)=1.25\n.ic V(OUT_PT100_BBOX)=1.25
