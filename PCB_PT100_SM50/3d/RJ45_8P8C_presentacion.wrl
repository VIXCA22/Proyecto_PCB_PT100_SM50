#VRML V2.0 utf8
WorldInfo { title "RJ45 8P8C right angle shielded - presentation model" }

# Visual-only generic model for KiCad presentation.
# Units are millimeters. Footprint accuracy still comes from the 2D footprint.

DEF SILVER Appearance { material Material { diffuseColor 0.72 0.72 0.68 specularColor 0.8 0.8 0.8 shininess 0.45 } }
DEF DARK Appearance { material Material { diffuseColor 0.02 0.025 0.03 specularColor 0.1 0.1 0.1 shininess 0.2 } }
DEF BLACK Appearance { material Material { diffuseColor 0.0 0.0 0.0 specularColor 0.05 0.05 0.05 shininess 0.15 } }
DEF GOLD Appearance { material Material { diffuseColor 0.95 0.68 0.18 specularColor 1.0 0.85 0.35 shininess 0.65 } }
DEF BLUE Appearance { material Material { diffuseColor 0.05 0.18 0.35 specularColor 0.15 0.25 0.45 shininess 0.25 } }

# Main metal shield body
Transform {
  translation 0 0 6.1
  children [
    Shape { appearance USE SILVER geometry Box { size 16.2 15.0 12.2 } }
  ]
}

# Slightly darker back cap
Transform {
  translation 0 -7.65 6.1
  children [ Shape { appearance USE DARK geometry Box { size 16.0 0.8 11.8 } } ]
}

# Front black RJ45 face
Transform {
  translation 0 7.85 5.8
  children [ Shape { appearance USE BLACK geometry Box { size 14.0 1.2 9.2 } } ]
}

# Inner socket opening
Transform {
  translation 0 8.5 5.6
  children [ Shape { appearance USE BLUE geometry Box { size 10.8 0.35 5.6 } } ]
}

# Top shield lip
Transform {
  translation 0 2.5 12.55
  children [ Shape { appearance USE SILVER geometry Box { size 15.6 9.2 0.8 } } ]
}

# Side shield tabs
Transform { translation -8.25 0 4.2 children [ Shape { appearance USE SILVER geometry Box { size 0.7 12.0 5.5 } } ] }
Transform { translation 8.25 0 4.2 children [ Shape { appearance USE SILVER geometry Box { size 0.7 12.0 5.5 } } ] }

