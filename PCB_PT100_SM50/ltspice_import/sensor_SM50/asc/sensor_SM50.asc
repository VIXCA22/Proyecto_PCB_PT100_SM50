TEXT 360 -328 Left 2 !.include ".\\proyecto_pcb_sensor_sm50.inc"\n.include ".\\INA826.lib"\n \n.param R0=350\n.param SENS=3m\n \n.param LB_FS=50\n.param KG_FS=22.6796\n \n* Barrido bipolar: torque negativo, cero y torque positivo.\n.step param PCT_SM50 list -100 -80 -60 -40 -20 0 20 40 60 80 100\n \n.param LB_APL={LB_FS*PCT_SM50/100}\n.param KG_APL={KG_FS*PCT_SM50/100}\n \n.param VEXC_SM50=10\n.param VBRIDGE_TARGET={SENS*VEXC_SM50*PCT_SM50/100}\n.param R3_SM50={R0*((VEXC_SM50/2 - VBRIDGE_TARGET)/(VEXC_SM50/2 + VBRIDGE_TARGET))}\n \n.param RG_SM=340\n.param G_SM={1+49.4k/RG_SM}\n \nBOUT_IDEAL_SM50 OUT_SM50_IDEAL 0 V={G_SM*V(SENP_SM50,SENN_SM50)}\n \n.tran 0 50m 0 100u\n \n.meas TRAN PORCENTAJE PARAM {PCT_SM50}\n.meas TRAN LIBRAS PARAM {LB_APL}\n.meas TRAN KILOS PARAM {KG_APL}\n.meas TRAN R3_VALUE PARAM {R3_SM50}\n \n.meas TRAN V_BRIDGE_V AVG V(SENP_SM50,SENN_SM50) FROM 10m TO 50m\n.meas TRAN V_BRIDGE_mV PARAM {1000*V_BRIDGE_V}\n \n.meas TRAN RG_INA826 PARAM {RG_SM}\n.meas TRAN GAIN_INA826 PARAM {G_SM}\n \n.meas TRAN V_OUT_BBOX AVG V(OUT_SM50_BBOX) FROM 10m TO 50m\n.meas TRAN V_OUT_BBOX_mV PARAM {1000*V_OUT_BBOX}\n \n.meas TRAN V_OUT_IDEAL AVG V(OUT_SM50_IDEAL) FROM 10m TO 50m\n.meas TRAN V_OUT_IDEAL_mV PARAM {1000*V_OUT_IDEAL}\n \n.meas TRAN ERROR_AMP PARAM {V_OUT_IDEAL - V_OUT_BBOX}\n \n.meas TRAN MARGEN_5V_REAL PARAM {5 - V_OUT_BBOX}\n.meas TRAN USO_RANGO_5V_REAL PARAM {100*V_OUT_BBOX/5}\n.meas TRAN MARGEN_ABS_5V_REAL PARAM {5 - abs(V_OUT_BBOX)}\n.meas TRAN USO_RANGO_ABS_5V_REAL PARAM {100*abs(V_OUT_BBOX)/5}\n \n.meas TRAN MARGEN_5V_IDEAL PARAM {5 - V_OUT_IDEAL}\n.meas TRAN USO_RANGO_5V_IDEAL PARAM {100*V_OUT_IDEAL/5}\n.meas TRAN MARGEN_ABS_5V_IDEAL PARAM {5 - abs(V_OUT_IDEAL)}\n.meas TRAN USO_RANGO_ABS_5V_IDEAL PARAM {100*abs(V_OUT_IDEAL)/5}\n \n.options reltol=1e-3\n.options abstol=1n\n.options vntol=1u\n.options gmin=1e-10\n.options gminsteps=0\n.options srcsteps=0
